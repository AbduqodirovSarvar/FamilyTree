# Copy this file to `.env` and adjust values for your environment.
# `.env` is read automatically by `docker compose` and is ignored by git.

# ───── Postgres ─────
# NOTE: 5433 (not 5432) is chosen by default to avoid clashes with a
# host-installed Postgres or other dev DBs. Inside the docker network
# the WebApi still talks to `db:5432` regardless of host port.
POSTGRES_DB=FamilyTree
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_PORT=5433

# ───── Redis ─────
# Same reasoning — 6380 host-side, 6379 internal.
REDIS_PORT=6380

# ───── WebApi ─────
WEBAPI_PORT=5009
ASPNETCORE_ENVIRONMENT=Production

# ───── JWT ─────
# IMPORTANT: rotate this secret in production. 32+ random chars.
JWT_SECRET=c822c478-ea26-46bc-83af-ce145ae2c110
JWT_ISSUER=https://family-tree.uz
JWT_AUDIENCE=https://family-tree.uz
